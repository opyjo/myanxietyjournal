{
  "name": "anxiety-journal",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "functions"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && npm run -w functions build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false && npm run -w functions typecheck",
    "test": "vitest run && npm run -w functions test",
    "test:watch": "vitest",
    "test:functions": "npm run -w functions test"
  },
  "dependencies": {
    "@hookform/resolvers": "^4.1.3",
    "firebase": "^11.6.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.56.3",
    "react-router-dom": "^7.5.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.1",
    "@types/react": "^19.1.1",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "jsdom": "^26.0.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.1",
    "vitest": "^3.1.1"
  }
}
